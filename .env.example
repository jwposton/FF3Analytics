# FOUND-02 — copy to .env and fill for Firefly III API access (Phase 2+).
# Never commit .env; token stays server-side only.

# Base URL of your Firefly III instance (trailing slash optional)
FIREFLY_BASE_URL=

# Personal access token from Firefly III (Profile → OAuth / Personal access tokens)
FIREFLY_API_TOKEN=

# Comma-separated browser origins allowed to call the API (CORS)
# Example: https://analytics.example.com,http://localhost:5174
CORS_ALLOWED_ORIGINS=https://analytics.example.com

